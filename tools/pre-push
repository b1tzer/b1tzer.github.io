#!/usr/bin/env bash
# pre-push hook：push 前自动运行 gen_nav.py，有变更则新建一个独立 commit 一起推送
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "🔧 [pre-push] 运行 gen_nav.py..."
python3 "$REPO_ROOT/tools/gen_nav.py"

# 检查是否有变更
CHANGED=$(git diff --name-only mkdocs.yml docs/index.md)
if [ -z "$CHANGED" ]; then
    echo "✅ [pre-push] 无变更，继续 push"
    exit 0
fi

echo "📝 [pre-push] 检测到以下文件变更，自动新建 commit："
echo "$CHANGED" | sed 's/^/   /'

git add mkdocs.yml docs/index.md
git commit --no-verify -m "chore: auto-update nav and index [skip ci]"

echo "✅ [pre-push] commit 完成，继续 push"

# ---------- Mermaid 语法预检（使用官方 @mermaid-js parser） ----------
if [ -f "$REPO_ROOT/package.json" ]; then
    echo "🔧 [pre-push] 运行 Mermaid 语法校验..."
    if [ ! -d "$REPO_ROOT/node_modules" ]; then
        echo "   检测到 node_modules 缺失，自动运行 npm install..."
        (cd "$REPO_ROOT" && npm install --silent) || {
            echo "❌ [pre-push] npm install 失败，push 终止"
            exit 1
        }
    fi
    (cd "$REPO_ROOT" && npm run --silent check:mermaid) || {
        echo "❌ [pre-push] Mermaid 语法校验失败，push 已终止"
        exit 1
    }
fi
